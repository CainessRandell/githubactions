{
  "openapi": "3.0.1",
  "info": {
    "title": "fivam API",
    "version": "1.0.0",
    "description": "API para autenticação e gerenciamento de posts."
  },
  "servers": [
    {
      "url": "http://localhost:3000"
    }
  ],
  "tags": [
    {
      "name": "Auth",
      "description": "Autenticação e registro"
    },
    {
      "name": "Posts",
      "description": "Leitura e gestão de posts"
    },
    {
      "name": "Usuarios",
      "description": "Consulta de usuarios"
    }
  ],
  "paths": {
    "/auth/register": {
      "post": {
        "tags": [
          "Auth"
        ],
        "summary": "Registrar novo usuário no Firebase (apenas professor)",
        "description": "Cria o usuario no Firebase Authentication com email/password e salva no banco o firebaseUid retornado pelo Firebase.",
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/RegisterInput"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Usuário criado"
          },
          "400": {
            "description": "Erro de validação ou usuário existente"
          },
          "401": {
            "description": "Não autorizado"
          },
          "403": {
            "description": "Apenas professor"
          }
        }
      }
    },
    "/auth/login": {
      "post": {
        "tags": [
          "Auth"
        ],
        "summary": "Realizar login com Firebase UID",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/LoginInput"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Login com sucesso, retorna token"
          },
          "400": {
            "description": "Credenciais inválidas"
          }
        }
      }
    },
    "/users": {
      "get": {
        "tags": [
          "Usuarios"
        ],
        "summary": "Listar usuarios",
        "description": "Lista usuarios autenticados com filtros opcionais por nome, email ou role.",
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "parameters": [
          {
            "name": "nome",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string"
            },
            "description": "Filtra usuarios por nome, aceitando busca parcial"
          },
          {
            "name": "email",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string",
              "format": "email"
            },
            "description": "Filtra usuarios por email, aceitando busca parcial"
          },
          {
            "name": "role",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string",
              "enum": [
                "professor",
                "aluno"
              ]
            },
            "description": "Filtra usuarios por perfil"
          }
        ],
        "responses": {
          "200": {
            "description": "Lista de usuarios",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/User"
                  }
                }
              }
            }
          },
          "400": {
            "description": "Filtro invalido"
          },
          "401": {
            "description": "Não autorizado"
          }
        }
      }
    },
    "/users/{id}": {
      "get": {
        "tags": [
          "Usuarios"
        ],
        "summary": "Obter usuario por ID",
        "description": "Busca um usuario pelo ID. Requer autenticacao.",
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Usuario encontrado",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/User"
                }
              }
            }
          },
          "400": {
            "description": "ID invalido"
          },
          "401": {
            "description": "Não autorizado"
          },
          "404": {
            "description": "Usuario nao encontrado"
          }
        }
      },
      "put": {
        "tags": [
          "Usuarios"
        ],
        "summary": "Atualizar usuario",
        "description": "Atualiza um usuario existente. Apenas professores podem executar esta acao.",
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/UserUpdateInput"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Usuario atualizado",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/User"
                }
              }
            }
          },
          "400": {
            "description": "Erro de validacao"
          },
          "401": {
            "description": "Não autorizado"
          },
          "403": {
            "description": "Apenas professor"
          },
          "404": {
            "description": "Usuario nao encontrado"
          }
        }
      },
      "delete": {
        "tags": [
          "Usuarios"
        ],
        "summary": "Excluir usuario",
        "description": "Remove um usuario existente. Apenas professores podem executar esta acao.",
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "204": {
            "description": "Usuario removido"
          },
          "400": {
            "description": "ID invalido"
          },
          "401": {
            "description": "Não autorizado"
          },
          "403": {
            "description": "Apenas professor"
          },
          "404": {
            "description": "Usuario nao encontrado"
          }
        }
      }
    },
    "/posts": {
      "get": {
        "tags": [
          "Posts"
        ],
        "summary": "Listar posts",
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "responses": {
          "200": {
            "description": "Lista de posts",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/Post"
                  }
                }
              }
            }
          },
          "401": {
            "description": "Não autorizado"
          }
        }
      },
      "post": {
        "tags": [
          "Posts"
        ],
        "summary": "Criar post (apenas professor)",
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/PostInput"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Post criado",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Post"
                }
              }
            }
          },
          "400": {
            "description": "Erro ao criar"
          },
          "401": {
            "description": "Não autorizado"
          },
          "403": {
            "description": "Apenas professor"
          }
        }
      }
    },
    "/posts/search": {
      "get": {
        "tags": [
          "Posts"
        ],
        "summary": "Buscar posts por texto",
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "parameters": [
          {
            "name": "q",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Texto para busca"
          }
        ],
        "responses": {
          "200": {
            "description": "Resultados da busca"
          },
          "400": {
            "description": "Parâmetro ausente"
          },
          "401": {
            "description": "Não autorizado"
          }
        }
      }
    },
    "/posts/{id}": {
      "get": {
        "tags": [
          "Posts"
        ],
        "summary": "Obter post por ID",
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Post encontrado"
          },
          "400": {
            "description": "ID inválido"
          },
          "404": {
            "description": "Post não encontrado"
          },
          "401": {
            "description": "Não autorizado"
          }
        }
      },
      "put": {
        "tags": [
          "Posts"
        ],
        "summary": "Atualizar post (apenas professor)",
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/PostInput"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Post atualizado"
          },
          "400": {
            "description": "Erro ao atualizar"
          },
          "401": {
            "description": "Não autorizado"
          },
          "403": {
            "description": "Apenas professor"
          },
          "404": {
            "description": "Post não encontrado"
          }
        }
      },
      "delete": {
        "tags": [
          "Posts"
        ],
        "summary": "Remover post (apenas professor)",
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "204": {
            "description": "Removido"
          },
          "400": {
            "description": "Erro ao remover"
          },
          "401": {
            "description": "Não autorizado"
          },
          "403": {
            "description": "Apenas professor"
          },
          "404": {
            "description": "Post não encontrado"
          }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT"
      }
    },
    "schemas": {
      "RegisterInput": {
        "type": "object",
        "required": [
          "nome",
          "email",
          "password"
        ],
        "properties": {
          "nome": {
            "type": "string"
          },
          "email": {
            "type": "string",
            "format": "email"
          },
          "password": {
            "type": "string",
            "format": "password",
            "description": "Senha inicial enviada ao Firebase Authentication. Nao e salva no banco da API.",
            "example": "123456"
          },
          "role": {
            "type": "string",
            "enum": [
              "professor",
              "aluno"
            ],
            "default": "aluno"
          }
        }
      },
      "LoginInput": {
        "type": "object",
        "required": [
          "firebaseUid"
        ],
        "properties": {
          "firebaseUid": {
            "type": "string",
            "description": "UID do usuario autenticado no Firebase Authentication",
            "example": "firebase-user-uid"
          }
        }
      },
      "User": {
        "type": "object",
        "properties": {
          "_id": {
            "type": "string"
          },
          "nome": {
            "type": "string",
            "example": "Joao teste"
          },
          "firebaseUid": {
            "type": "string",
            "example": "firebase-user-uid"
          },
          "email": {
            "type": "string",
            "format": "email",
            "example": "joao@escola.com"
          },
          "role": {
            "type": "string",
            "enum": [
              "professor",
              "aluno"
            ],
            "example": "aluno"
          }
        }
      },
      "UserUpdateInput": {
        "type": "object",
        "properties": {
          "nome": {
            "type": "string",
            "example": "Joao Silva"
          },
          "email": {
            "type": "string",
            "format": "email",
            "example": "joao.silva@escola.com"
          },
          "firebaseUid": {
            "type": "string",
            "example": "firebase-user-uid"
          },
          "role": {
            "type": "string",
            "enum": [
              "professor",
              "aluno"
            ],
            "example": "aluno"
          }
        }
      },
      "PostInput": {
        "type": "object",
        "required": [
          "titulo",
          "conteudo"
        ],
        "properties": {
          "titulo": {
            "type": "string",
            "example": "O que e um verbo: explicacao completa para entender"
          },
          "conteudo": {
            "type": "string",
            "example": "Primeiro paragrafo.\\nSegundo paragrafo."
          },
          "autor": {
            "type": "string",
            "example": "Joao teste"
          }
        }
      },
      "Post": {
        "allOf": [
          {
            "$ref": "#/components/schemas/PostInput"
          },
          {
            "type": "object",
            "properties": {
              "_id": {
                "type": "string"
              },
              "dataCriacao": {
                "type": "string",
                "format": "date-time"
              }
            }
          }
        ]
      }
    }
  }
}
